local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local IsFlying = false
local IsNoclip = false
local FlySpeed = 60

-- Xóa menu cũ
if CoreGui:FindFirstChild("FlyMenuMobile") then CoreGui:FindFirstChild("FlyMenuMobile"):Destroy() end

-- 1. TẠO MENU
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "FlyMenuMobile"
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 180, 0, 180)
MainFrame.Position = UDim2.new(0.5, -90, 0.4, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Active = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 12)

-- HÀM KÉO THẢ
local dragging, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

-- NÚT BAY
local FlyBtn = Instance.new("TextButton", MainFrame)
FlyBtn.Size = UDim2.new(0, 150, 0, 40); FlyBtn.Position = UDim2.new(0.5, -75, 0.1, 0)
FlyBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50); FlyBtn.Text = "BAY: TẮT"
Instance.new("UICorner", FlyBtn).CornerRadius = UDim.new(0, 8)

-- NÚT XUYÊN TƯỜNG
local NoclipBtn = Instance.new("TextButton", MainFrame)
NoclipBtn.Size = UDim2.new(0, 150, 0, 40); NoclipBtn.Position = UDim2.new(0.5, -75, 0.4, 0)
NoclipBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 255); NoclipBtn.Text = "XUYÊN: TẮT"
Instance.new("UICorner", NoclipBtn).CornerRadius = UDim.new(0, 8)

-- ĐIỀU KHIỂN TỐC ĐỘ
local SpeedLabel = Instance.new("TextLabel", MainFrame)
SpeedLabel.Size = UDim2.new(0, 100, 0, 30); SpeedLabel.Position = UDim2.new(0.5, -50, 0.75, 0)
SpeedLabel.BackgroundTransparency = 1; SpeedLabel.Text = "Tốc độ: 60"
local DecBtn = Instance.new("TextButton", MainFrame)
DecBtn.Size = UDim2.new(0, 30, 0, 30); DecBtn.Position = UDim2.new(0.1, 0, 0.75, 0); DecBtn.Text = "-"
local IncBtn = Instance.new("TextButton", MainFrame)
IncBtn.Size = UDim2.new(0, 30, 0, 30); IncBtn.Position = UDim2.new(0.75, 0, 0.75, 0); IncBtn.Text = "+"

DecBtn.MouseButton1Click:Connect(function() FlySpeed = math.max(10, FlySpeed - 10); SpeedLabel.Text = "Tốc độ: "..FlySpeed end)
IncBtn.MouseButton1Click:Connect(function() FlySpeed = math.min(300, FlySpeed + 10); SpeedLabel.Text = "Tốc độ: "..FlySpeed end)

-- LOGIC XUYÊN TƯỜNG
RunService.Stepped:Connect(function()
    if IsNoclip and LocalPlayer.Character then
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
        end
    end
end)

NoclipBtn.MouseButton1Click:Connect(function()
    IsNoclip = not IsNoclip
    NoclipBtn.Text = IsNoclip and "XUYÊN: BẬT" or "XUYÊN: TẮT"
    NoclipBtn.BackgroundColor3 = IsNoclip and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(100, 100, 255)
end)

-- LOGIC BAY (Giữ nguyên)
local BV, BG
FlyBtn.MouseButton1Click:Connect(function()
    IsFlying = not IsFlying
    local HRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local Humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not HRP then return end
    
    if IsFlying then
        FlyBtn.Text = "BAY: BẬT"; FlyBtn.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
        Humanoid:ChangeState(Enum.HumanoidStateType.Physics)
        BV = Instance.new("BodyVelocity", HRP); BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        BG = Instance.new("BodyGyro", HRP); BG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); BG.CFrame = Camera.CFrame
        task.spawn(function()
            while IsFlying and HRP.Parent do
                local dir = Humanoid.MoveDirection
                BV.Velocity = (dir.Magnitude > 0 and (dir:Dot(Camera.CFrame.LookVector) > -0.5 and Camera.CFrame.LookVector or dir) * FlySpeed) or Vector3.zero
                BG.CFrame = Camera.CFrame
                RunService.RenderStepped:Wait()
            end
        end)
    else
        FlyBtn.Text = "BAY: TẮT"; FlyBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        if BV then BV:Destroy() end; if BG then BG:Destroy() end
    end
end)
