local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local IsFlying = false
local IsNoclip = false
local IsFastRun = false
local SpeedValue = 60 -- Tốc độ chung cho cả bay và chạy nhanh

-- Xóa menu cũ nếu trùng
if CoreGui:FindFirstChild("FlyMenuMobile") then CoreGui:FindFirstChild("FlyMenuMobile"):Destroy() end

-- 1. TẠO MENU CHÍNH (Nới rộng bảng lên một chút để thêm nút)
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "FlyMenuMobile"
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 180, 0, 230)
MainFrame.Position = UDim2.new(0.5, -90, 0.35, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Active = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 12)

-- HÀM KÉO THẢ MENU MƯỢT MÀ
local dragging, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

