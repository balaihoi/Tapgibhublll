-- SỰ KIỆN TĂNG GIẢM TỐC ĐỘ
DecBtn.MouseButton1Click:Connect(function() 
    SpeedValue = math.max(16, SpeedValue - 10) 
    SpeedLabel.Text = "Tốc độ: " .. SpeedValue 
end)
IncBtn.MouseButton1Click:Connect(function() 
    SpeedValue = math.min(300, SpeedValue + 10) 
    SpeedLabel.Text = "Tốc độ: " .. SpeedValue 
end)

-- VÒNG LẶP HỆ THỐNG (Xử lý Xuyên tường & Chạy nhanh liên tục để tránh game reset)
RunService.Stepped:Connect(function()
    local Character = LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    
    -- Xử lý xuyên tường
    if IsNoclip and Character then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
        end
    end
    
    -- Xử lý chạy nhanh khi không bay
    if Humanoid and not IsFlying then
        if IsFastRun then
            Humanoid.WalkSpeed = SpeedValue
        else
            Humanoid.WalkSpeed = 16 -- Tốc độ mặc định của Roblox
        end
    end
end)

-- BẬT/TẮT CHẠY NHANH
RunBtn.MouseButton1Click:Connect(function()
    IsFastRun = not IsFastRun
    RunBtn.Text = IsFastRun and "CHẠY NHANH: BẬT" or "CHẠY NHANH: TẮT"
    RunBtn.BackgroundColor3 = IsFastRun and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(230, 130, 10)
end)

-- BẬT/TẮT XUYÊN TƯỜNG
NoclipBtn.MouseButton1Click:Connect(function()
